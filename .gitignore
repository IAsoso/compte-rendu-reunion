# Environnement virtuel Python (lourd, se recrée localement)
venv/

# Fichiers de secrets / configuration (clés d'API) — JAMAIS en ligne
.env

# Fichiers temporaires Python
__pycache__/
*.pyc

# Base de données SQLite (données locales, ne doivent pas partir en ligne)
synthia.db
*.db

# Sauvegardes locales de la base (copies horodatées + filet de restauration)
backups/
*.avant-restauration-*

# Configuration locale Claude Code (machine de dev uniquement)
.claude/
